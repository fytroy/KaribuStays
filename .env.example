# --- Database (PostgreSQL via Neon — free at https://neon.tech) ---
DATABASE_URL="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require"

# --- NextAuth ---
AUTH_SECRET="generate-with: openssl rand -base64 32"
NEXTAUTH_URL="https://yourdomain.vercel.app"

# --- Google OAuth (optional) ---
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# --- M-Pesa Daraja (Safaricom) ---
# Sandbox creds: https://developer.safaricom.co.ke
MPESA_ENV="sandbox"
MPESA_CONSUMER_KEY=""
MPESA_CONSUMER_SECRET=""
MPESA_SHORTCODE="174379"
MPESA_PASSKEY=""
MPESA_CALLBACK_URL="https://yourdomain.vercel.app/api/mpesa/callback"

# --- Resend (email — verification & password reset) ---
# Free API key: https://resend.com
RESEND_API_KEY=""
RESEND_FROM="Karibu Stays <noreply@yourdomain.com>"

# --- Cloudinary (image uploads) ---
# Free account: https://cloudinary.com
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# --- App ---
NEXT_PUBLIC_APP_URL="https://yourdomain.vercel.app"
